# ── MarketSpot 환경변수 예시 ─────────────────────────────────────
# 이 파일을 .env 로 복사해서 사용하세요. 키가 없어도 앱은 기동되며
# 공개 시장 데이터(yfinance)는 동작합니다. 키가 없는 기능은 화면에
# "API 키 필요" 로 정직하게 표기됩니다.
#
# ⚠️ .env 와 data/settings.json 은 절대 공유/커밋하지 마세요(.gitignore 등록됨).

# ── 데이터 저장 위치 ─────────────────────────────────────────────
STOCK_TERMINAL_DATA_DIR=./data

# ── SEC 공시(EDGAR) 조회용 User-Agent — 연락처 포함 권장 ─────────
# SEC EDGAR는 요청 시 연락처가 담긴 User-Agent를 요구합니다. 비워두면
# 코드 기본값(익명 예시)이 쓰입니다.
SEC_USER_AGENT=

# ── CORS (로컬 개발: Vite dev 서버) ──────────────────────────────
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000

# ── 프로덕션 정적 프론트 경로(빌드 후) ──────────────────────────
# FRONTEND_DIST=./static

# ── 선택: 데이터 제공자 API 키 (없으면 yfinance 기본 사용) ───────
# Alpaca (미국 종목 근실시간 보조)  https://alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Finnhub (뉴스)  https://finnhub.io
FINNHUB_API_KEY=
# DART (한국 공시)  https://opendart.fss.or.kr
DART_API_KEY=
# FRED (미국 금리)  https://fred.stlouisfed.org
FRED_API_KEY=
# 한국투자증권 KIS (한국 실시간)  https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=

# ── 선택: AI ─────────────────────────────────────────────────────
# 기본은 로컬 Ollama (키 불필요). Gemini 를 쓰려면 키 입력.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-vl:8b
GEMINI_API_KEY=
